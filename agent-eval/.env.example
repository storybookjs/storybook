# API Keys (choose one based on your agent)
# For vercel-ai-gateway agents or to enable failure classification:
AI_GATEWAY_API_KEY=your-ai-gateway-api-key

# For direct Claude Code API:
# ANTHROPIC_API_KEY=sk-ant-...

# For direct OpenAI Codex API:
# OPENAI_API_KEY=sk-proj-...

# Sandbox access
# agent-eval uses Vercel Sandbox when Vercel access-token credentials are set.
# Without VERCEL_TOKEN, sandbox: 'auto' falls back to Docker.

# Option 1: Vercel access-token credentials (recommended for CI)
# Create a classic personal token at: https://vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-token
VERCEL_TEAM_ID=team_xxx
VERCEL_PROJECT_ID=prj_xxx

# Alternative: Use Docker instead of Vercel sandbox (no token needed)
# Leave VERCEL_TOKEN unset while using sandbox: 'auto', or set sandbox: 'docker'.
