{
  "name": "code",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "tags": ["library"],
  "targets": {
    "lint": {
      "dependsOn": [{ "projects": ["*"], "target": "compile" }],
      "executor": "nx:run-commands",
      "options": { "cwd": "{projectRoot}", "command": "yarn lint" },
      "cache": true,
      "inputs": ["default"],
      "configurations": { "production": {} }
    },
    "test": {
      "dependsOn": [{ "projects": ["*"], "target": "compile" }],
      "executor": "nx:run-commands",
      "options": { "command": "yarn test" },
      "cache": true,
      "inputs": ["{workspaceRoot}/code/**/*", "{workspaceRoot}/vitest.config.ts"],
      "configurations": { "production": {} }
    },
    "knip": {
      "dependsOn": [{ "projects": ["*"], "target": "compile" }],
      "executor": "nx:run-commands",
      "options": { "cwd": "{projectRoot}", "command": "yarn knip --no-exit-code" },
      "cache": true,
      "inputs": ["default"],
      "configurations": { "production": {} }
    },
    "storybook-build": {
      "dependsOn": [{ "projects": ["*"], "target": "compile" }],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "yarn storybook:ui:build"
      },
      "cache": true,
      "inputs": ["default", "^production"],
      "outputs": ["{projectRoot}/storybook-static"],
      "configurations": { "production": {} }
    },
    "storybook-chromatic": {
      "dependsOn": ["storybook-build"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "yarn storybook:ui:chromatic"
      },
      "cache": true,
      "configurations": { "production": {} }
    }
  }
}
