{
  "name": "scripts",
  "tags": ["library"],
  "includedScripts": [],
  "targets": {
    "pretty-docs": {
      "command": "yarn fmt:check",
      "cwd": "{projectRoot}",
      "cache": true,
      "inputs": ["{workspaceRoot}/docs/**/*", "{workspaceRoot}/docs/.oxfmtrc.json"]
    },
    "check": {
      "dependsOn": [],
      "executor": "nx:run-commands",
      "options": { "cwd": "{projectRoot}", "command": "yarn check" },
      "inputs": ["default"],
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "cwd": "{projectRoot}", "command": "yarn lint" },
      "cache": true,
      "inputs": ["default"],
      "configurations": { "production": {} }
    },
    "run-registry": {},
    "publish": {}
  }
}
