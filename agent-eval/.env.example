# API Keys
# For direct Claude Code API and failure classification:
ANTHROPIC_API_KEY=sk-ant-...

# Alternative for failure classification and vercel-ai-gateway/* agents:
# AI_GATEWAY_API_KEY=your-ai-gateway-api-key

# For direct OpenAI Codex API:
# OPENAI_API_KEY=sk-proj-...

# Sandbox access
# This suite is configured with sandbox: 'auto': it uses Vercel Sandbox when the
# three Vercel access-token credentials below are set, and falls back to local
# Docker otherwise (credentials only required for Vercel Sandbox / CI).

# Vercel access-token credentials (required in external CI)
# Create a classic personal token at: https://vercel.com/account/tokens
VERCEL_PROJECT_ID=prj_xxx
VERCEL_TEAM_ID=team_xxx
VERCEL_TOKEN=your-vercel-token

# Local alternative to the access token: run `vercel link` (project
# storybook-evals) once, then `vercel env pull` to write a short-lived
# VERCEL_OIDC_TOKEN into .env.local. Re-run `vercel env pull` when it expires.
# Note: `vercel env pull` overwrites .env.local, so re-add your API keys after.

# Alternative: for local Docker-only experiments, change the eval config to
# sandbox: 'docker' and leave these Vercel credentials unset.
