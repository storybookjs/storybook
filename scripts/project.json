{
  "name": "scripts",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "tags": ["library"],
  "includedScripts": [],
  "targets": {
    "pretty-docs": {
      "command": "yarn docs:fmt:check",
      "cache": true,
      "inputs": ["{workspaceRoot}/docs/**/*"]
    },
    "check": {
      "dependsOn": [],
      "executor": "nx:run-commands",
      "options": { "cwd": "{projectRoot}", "command": "yarn check" },
      "inputs": ["default"],
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "cwd": "{projectRoot}", "command": "yarn lint" },
      "cache": true,
      "inputs": ["default"],
      "configurations": { "production": {} }
    },
    "run-registry": {},
    "publish": {},
    "bench-packages": {
      "dependsOn": ["run-registry"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "yarn bench-packages --base-branch ${GH_BASE_BRANCH:-next} --pull-request ${GH_PR_NUMBER:-0} --upload"
      },
      "cache": true,
      "configurations": { "production": {} }
    }
  }
}
