		"@storybook/mcp": "file:./local-packages/mcp",
		"@storybook/react-vite": "10.5.0-alpha.9",
		"@types/node": "24.10.1",
		"@types/react": "19.2.6",
		"@types/react-dom": "19.2.3",
		"@vercel/agent-eval": "^1.2.0",
		"@vitejs/plugin-react-swc": "4.2.2",
		"@vitest/browser-playwright": "4.0.6",
