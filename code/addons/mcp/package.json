{
  "name": "@storybook/addon-mcp",
  "version": "10.6.0-alpha.2",
  "description": "Help agents automatically write and test stories for your UI components",
  "keywords": [
    "ai",
    "mcp",
    "storybook-addon"
  ],
  "homepage": "https://github.com/storybookjs/storybook/tree/next/code/addons/mcp",
  "bugs": {
    "url": "https://github.com/storybookjs/storybook/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/storybookjs/storybook.git",
    "directory": "code/addons/mcp"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/storybook"
  },
  "license": "MIT",
  "author": "Storybook Core Team",
  "type": "module",
  "exports": {
    "./internal/preview-stories-app-script": "./dist/tools/preview-stories/preview-stories-app-script.js",
    "./package.json": "./package.json",
    "./preset": "./dist/preset.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts",
    "!src/**/*"
  ],
  "dependencies": {
    "@storybook/mcp": "workspace:*",
    "@tmcp/adapter-valibot": "^0.1.5",
    "@tmcp/transport-http": "^0.8.5",
    "picoquery": "^2.5.0",
    "tmcp": "^1.19.4",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "workspace:*",
    "@storybook/addon-vitest": "workspace:*",
    "storybook": "workspace:*",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@storybook/addon-vitest": "workspace:^",
    "storybook": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@storybook/addon-vitest": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.storybookjs/addon-mcp",
  "storybook": {
    "displayName": "Addon MCP",
    "supportedFrameworks": [
      "react",
      "vue3",
      "angular",
      "web-components",
      "html",
      "svelte",
      "preact",
      "react-native"
    ],
    "icon": "https://user-images.githubusercontent.com/321738/63501763-88dbf600-c4cc-11e9-96cd-94adadc2fd72.png"
  }
}
