{
  "name": "@storybook/mcp-internal-storybook",
  "version": "0.0.0",
  "private": true,
  "description": "The Storybook used to test the MCP packages in the monorepo",
  "scripts": {
    "build-storybook": "storybook build",
    "storybook": "storybook dev --port 6006 --loglevel debug --no-open",
    "storybook:composition": "storybook dev --port 6007 -c .storybook-composition --loglevel debug --no-open",
    "storybook:composition:auth": "storybook dev --port 6008 -c .storybook-composition-auth --loglevel debug --no-open",
    "storybook:composition:docgen-server": "storybook dev --port 6009 -c .storybook-composition-docgen-server --loglevel debug --no-open",
    "test": "vitest --project=e2e",
    "test:storybook": "vitest run --project=storybook",
    "typecheck": "tsc"
  },
  "resolutions": {
    "@storybook/addon-a11y": "file:../../code/addons/a11y",
    "@storybook/addon-docs": "file:../../code/addons/docs",
    "@storybook/addon-links": "file:../../code/addons/links",
    "@storybook/addon-mcp": "file:../../code/addons/mcp",
    "@storybook/addon-themes": "file:../../code/addons/themes",
    "@storybook/addon-vitest": "file:../../code/addons/vitest",
    "@storybook/builder-vite": "file:../../code/builders/builder-vite",
    "@storybook/csf-plugin": "file:../../code/lib/csf-plugin",
    "@storybook/mcp": "file:../../code/lib/mcp",
    "@storybook/react": "file:../../code/renderers/react",
    "@storybook/react-dom-shim": "file:../../code/lib/react-dom-shim",
    "@storybook/react-vite": "file:../../code/frameworks/react-vite",
    "playwright": "1.58.2",
    "storybook": "file:../../code/core"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.0.0",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/addon-mcp": "^10.0.0",
    "@storybook/addon-themes": "^10.0.0",
    "@storybook/addon-vitest": "^10.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser-playwright": "4.0.6",
    "playwright": "1.58.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^10.0.0",
    "tinyexec": "^1.0.2",
    "vite": "7.2.2",
    "vitest": "4.0.6"
  }
}
